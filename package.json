{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/jquery": "^4.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "dotenv": "^17.4.2",
    "dropzone": "^6.0.0-beta.2",
    "jquery": "^4.0.0",
    "lodash": "^4.18.1",
    "preline": "^4.2.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "ytmusic-api": "https://github.com/CBurgi/ts-npm-ytmusic-api.git"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/bun": "latest",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15"
  },
  "module": "src/index.ts",
  "peerDependencies": {
    "typescript": "^5"
  }
}
